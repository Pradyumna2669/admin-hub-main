VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_JAAS_APP_ID="your-jaas-app-id"
VITE_GIPHY_API_KEY="your-giphy-api-key"
VITE_WEB_PUSH_PUBLIC_KEY="your-web-push-public-key"
PUBLIC_SITE_URL="https://your-site.example"
# Server-side Discord verification values.
# These must exist in the Supabase Edge Function secrets for `sync-discord-verification`,
# and should also be available to the Discord bot runtime if you run the bot separately.
DISCORD_BOT_TOKEN="discord-bot-token"
DISCORD_GUILD_ID="your-discord-guild-id"
DISCORD_VERIFIED_ROLE_ID="your-verified-role-id"
DISCORD_UNVERIFIED_ROLE_ID="your-unverified-role-id"
PUBLIC_DISCORD_INVITE_URL="https://discord.gg/your-invite"
SUPABASE_SERVICE_ROLE_KEY="server-only-service-role-key"
CRON_SECRET="server-only-cron-secret"
VITE_ARCADE_SURVIVOR_SERVER_URL="http://localhost:3101"
ARCADE_SURVIVOR_PORT="3101"
ARCADE_SURVIVOR_CLIENT_ORIGIN="http://localhost:8080"

# Blaster Royale arcade server
VITE_BLASTER_SERVER_URL=http://localhost:3001
BLASTER_PORT=3001
BLASTER_CLIENT_ORIGIN=http://localhost:8080
